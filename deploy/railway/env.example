# Variaveis do servico ulysses no Railway (opcional, defaults ok na maioria)

OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
WORKERS=1
LEGAL_NER_MODEL=dominguesm/legal-bert-ner-base-cased-ptbr
LEGAL_NER_MAX_LENGTH=512
LEGAL_NER_STRIDE=128
LEGAL_NER_AGGREGATION=first
LEGAL_NER_JURISPRUDENCIA_THRESHOLD=0.35
CORS_ORIGINS=*

# Na api + worker do RAGjuridico (Shared Variables):
# LEGAL_NER_ENDPOINT=http://${{ulysses.RAILWAY_PRIVATE_DOMAIN}}/api/v1/extract
#
# Se a conexao privada falhar, confira em Networking o port mapping do servico
# (deve bater com $PORT do container, tipicamente injetado pelo Railway).
